---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home" description="Reproducible, hypothesis-driven experiments on AI system behavior. Open science from Misty Step.">
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-16">
    <div class="max-w-3xl">
      <p class="text-sm font-mono uppercase tracking-widest text-amber-500 mb-4">
        Computational Laboratory
      </p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-stone-900 dark:text-stone-100 leading-tight">
        Reproducible experiments on<br />AI system behavior
      </h1>
      <p class="mt-6 text-lg text-stone-600 dark:text-stone-400 leading-relaxed max-w-2xl">
        We run hypothesis-driven experiments measuring how LLM agents respond to adversarial
        input, defense configurations, and context strategies. All data open. All experiments
        reproducible. Findings published only from live data.
      </p>
      <div class="mt-8 flex items-center gap-4">
        <a
          href="/about"
          class="inline-block bg-amber-500 hover:bg-amber-400 text-white font-semibold px-5 py-2.5 rounded-lg transition-colors"
        >
          Our methodology &rarr;
        </a>
        <a
          href="https://github.com/misty-step/laboratory"
          class="text-sm text-stone-500 hover:text-stone-700 dark:hover:text-stone-300 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Status -->
  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="border border-amber-200 dark:border-amber-900/50 bg-amber-50 dark:bg-amber-900/10 rounded-xl p-8">
      <p class="text-sm font-mono uppercase tracking-widest text-amber-500 mb-3">
        Status
      </p>
      <h2 class="text-xl font-semibold text-stone-900 dark:text-stone-100 mb-2">
        First experiment in progress
      </h2>
      <p class="text-stone-600 dark:text-stone-400 max-w-xl">
        The lab is open. We're designing the next experiment. Findings will be published
        here once live data collection is complete and peer review passes.
      </p>
      <p class="mt-4 text-sm text-stone-500 dark:text-stone-500">
        Subscribe for findings &rarr; <span class="font-mono">lab@mistystep.com</span>
      </p>
    </div>
  </section>
</BaseLayout>
